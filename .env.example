# Single-model runs: an OpenAI-compatible endpoint and the reference baseline's inference settings
# (also the fallback when OPENAI_PROVIDERS is unset). Pin each value to the model publisher's
# recommendation and record it in the run fingerprint (PRINCIPLES Law 13).
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=gsk_***
OPENAI_MODEL=openai/gpt-oss-20b
OPENAI_TEMPERATURE=1.0
OPENAI_TOP_P=1.0
OPENAI_REASONING_EFFORT=medium          # reasoning models only; instruct models reject it
OPENAI_MAX_COMPLETION_TOKENS=32768

# Client-side rate governor: paces every call under the provider's limits with explicit backoff.
OPENAI_TPM=250000
OPENAI_RPM=1000
OPENAI_MAX_RETRIES=8
OPENAI_BACKOFF_BASE=1.0

# Heterogeneous multi-model debate. OPENAI_PROVIDERS is a comma-separated list of provider URLs,
# one per agent; when set it replaces the single-model vars above. Each entry is base_url?<query>,
# with params in the query: keys are case-insensitive, - and _ interchange, max_tokens aliases
# max_completion_tokens, per-provider rpm/tpm (0 = no limit). The last entry is the captain unless
# one sets &role=captain. No value may contain a comma.
OPENAI_PROVIDERS=http://localhost:11434/v1?model=nemotron-3-nano:30b&api_key=dummy&temperature=1.0&top_p=1.0&max_tokens=32768,http://localhost:11434/v1?model=mistral-small3.2&api_key=dummy&temperature=0.15&max_tokens=32768,http://localhost:11434/v1?model=qwen3.6:35b&api_key=dummy&temperature=1.0&top_p=0.95&max_tokens=32768,http://localhost:11434/v1?model=gpt-oss:20b&api_key=dummy&temperature=1.0&top_p=1.0&reasoning_effort=medium&max_tokens=32768

# Available local models (Ollama) with publisher-recommended params (researched + verified). Copy
# the ones you want into OPENAI_PROVIDERS above; gpt-oss is the suggested captain (most reliable at
# emitting the conclude tool call).
OPENAI_PROVIDER_GPT_OSS_20B=http://localhost:11434/v1?model=gpt-oss:20b&api_key=dummy&temperature=1.0&top_p=1.0&reasoning_effort=medium&max_tokens=32768
OPENAI_PROVIDER_NEMOTRON_3_NANO_30B=http://localhost:11434/v1?model=nemotron-3-nano:30b&api_key=dummy&temperature=1.0&top_p=1.0&max_tokens=32768
OPENAI_PROVIDER_MISTRAL_SMALL3_2=http://localhost:11434/v1?model=mistral-small3.2&api_key=dummy&temperature=0.15&max_tokens=32768
OPENAI_PROVIDER_QWEN3_6_35B=http://localhost:11434/v1?model=qwen3.6:35b&api_key=dummy&temperature=1.0&top_p=0.95&max_tokens=32768

# Gated datasets (GPQA) need a Hugging Face token.
HF_TOKEN=
