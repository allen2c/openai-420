OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=gsk_***
OPENAI_MODEL=openai/gpt-oss-20b
OPENAI_TEMPERATURE=1.0
OPENAI_REASONING_EFFORT=medium   # effort must match difficulty: `low` cripples hard sets (AIME
                                 # single 50%→20%); keep medium+ for hard math, big budget below
OPENAI_MAX_COMPLETION_TOKENS=32768   # 32k fits most datasets without truncation; gpt-oss at
                                     # medium burns the whole budget reasoning on hard problems
OPENAI_TOP_P=1.0

# Client-side rate governing (optional; Groq gpt-oss-20b on_demand defaults shown). The harness
# paces every call under these limits and owns an explicit backoff, so a token-heavy run never
# exhausts retries on a 429. Lower TPM if you share the org quota; raise concurrency freely since
# the governor — not --concurrency — is what bounds the real token rate.
OPENAI_TPM=250000
OPENAI_RPM=1000
OPENAI_MAX_RETRIES=8
OPENAI_BACKOFF_BASE=1.0

HF_TOKEN=
